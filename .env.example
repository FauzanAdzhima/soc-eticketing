APP_NAME=Laravel
APP_ENV=local
APP_KEY=
APP_DEBUG=true
# URL publik aplikasi (produksi: https://domain-anda). Dipakai untuk tautan absolut di email dan EHLO SMTP.
APP_URL=http://localhost

# Zona waktu tampilan & Carbon (WIB). Contoh lain: Asia/Makassar, Asia/Jayapura
APP_TIMEZONE=Asia/Jakarta

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=sqlite
# DB_HOST=127.0.0.1
# DB_PORT=3306
# DB_DATABASE=laravel
# DB_USERNAME=root
# DB_PASSWORD=

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
# Untuk WebSocket (Laravel Reverb): set ke reverb, jalankan `php artisan reverb:start`, dan isi kunci di bawah.
# Lihat https://laravel.com/docs/broadcasting
# REVERB_APP_ID=
# REVERB_APP_KEY=
# REVERB_APP_SECRET=
# REVERB_HOST=localhost
# REVERB_PORT=8080
# REVERB_SCHEME=http

# Variabel VITE_* dipakai oleh resources/js/bootstrap.js (Echo). Salin REVERB_APP_KEY ke VITE_REVERB_APP_KEY.
# VITE_REVERB_APP_KEY=
# VITE_REVERB_HOST=localhost
# VITE_REVERB_PORT=8080
# VITE_REVERB_SCHEME=http
FILESYSTEM_DISK=local
# Email pelapor (ReporterTicketCreatedMail) di-queue: jalankan worker di server produksi, mis. `php artisan queue:work`
# atau gunakan supervisor/systemd agar proses tetap hidup. Tanpa worker, email tertahan di tabel `jobs`.
QUEUE_CONNECTION=database

CACHE_STORE=database
# CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

# --- Email ---
# Uji lokal: MAIL_MAILER=log menulis ke storage/logs; atau Mailpit (https://github.com/axllent/mailpit):
#   MAIL_MAILER=smtp, MAIL_HOST=127.0.0.1, MAIL_PORT=1025, MAIL_USERNAME=null, MAIL_PASSWORD=null
# Email pemberitahuan tiket ke pelapor di-queue (lihat juga komentar QUEUE_CONNECTION): jalankan `php artisan queue:work`
# (produksi: supervisor/systemd). Uji kirim dari tinker: Mail::raw(...)
#
# Produksi (Zimbra / SMTP perusahaan) — minta ke admin IT:
#   - Hostname SMTP (bukan URL webmail), port (umum 587 + STARTTLS atau 465 + SSL)
#   - Apakah submission terbuka dari IP server aplikasi; bila relay dibatasi, minta whitelist IP server Laravel
#   - Username = alamat email lengkap, password kotak; MAIL_FROM_ADDRESS = kotak yang diizinkan mengirim (sering = MAIL_USERNAME)
# Laravel: jika MAIL_SCHEME kosong, port 465 memakai smtps; selain itu smtp (587 biasanya STARTTLS otomatis lewat Symfony Mailer).
# Alternatif satu baris: MAIL_URL=smtp://user:pass@mail.domain.go.id:587
#
# Contoh produksi (isi dari jawaban IT; jangan commit .env nyata):
# MAIL_MAILER=smtp
# MAIL_SCHEME=
# MAIL_HOST=mail.domain.go.id
# MAIL_PORT=587
# MAIL_USERNAME=noreply@domain.go.id
# MAIL_PASSWORD=
# MAIL_FROM_ADDRESS=noreply@domain.go.id
# MAIL_FROM_NAME="SOC eTicketing"
MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"
# MAIL_URL=
# MAIL_EHLO_DOMAIN=   # opsional; default dari host APP_URL

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

VITE_APP_NAME="${APP_NAME}"
